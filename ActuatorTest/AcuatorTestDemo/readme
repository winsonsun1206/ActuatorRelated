# set the velocity to 0 to stop motion
cansend can1 003#1200000000020000
#set to velocity control mode:
cansend can0 003#0303000000000000
# clear up error
cansend can1 003#0001000000000000
#power up
cansend can1 003#0189FD8613000000
#control the speed to 150rad/s
cansend can1 003#1200001643020000
#control the speed to -150rad/s
cansend can1 003#12000016C3020000
#disable dummy streaming
cansend can1 003#2500000000000000

#???
#set streaming parameters
cansend can1 003#2F400D0300000000
cansend can1 003#320F000000000000
#set 500ms(2Hz) running
cansend can1 003#3020A10700000000
cansend can1 003#331F3C0000000000


